DISCORD_TOKEN=your_discord_bot_token_here

# --- SQL Server stats database ---
# Defaults: localhost / SmokeysRadio / Windows authentication.
# Override only the pieces you need.
# SMOKEYS_DB_SERVER=localhost
# SMOKEYS_DB_NAME=SmokeysRadio
# SMOKEYS_DB_DRIVER=ODBC Driver 17 for SQL Server
# SMOKEYS_DB_TRUSTED=yes      # set to "no" to use SQL auth (then set USER + PASSWORD)
# SMOKEYS_DB_USER=
# SMOKEYS_DB_PASSWORD=
#
# OR provide a full ODBC connection string (overrides everything above):
# SMOKEYS_DB_CONN=DRIVER={ODBC Driver 17 for SQL Server};SERVER=...;DATABASE=...;UID=...;PWD=...;
#
# To disable DB logging entirely:
# SMOKEYS_DB_DISABLED=true
